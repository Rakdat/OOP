<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="10" style="-fx-background-color: #2b2b2b; -fx-padding: 10;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.nsu.tokarev4.SnakeController">

    <Label fx:id="scoreLabel" text="Настрой игру и погнали!" textFill="WHITE">
        <font><Font name="System Bold" size="24.0" /></font>
    </Label>

    <StackPane fx:id="canvasContainer" minWidth="0" minHeight="0" VBox.vgrow="ALWAYS" prefWidth="600" prefHeight="600" style="-fx-background-color: black;">

        <Canvas fx:id="gameCanvas" />

        <VBox fx:id="settingsBox" alignment="CENTER" spacing="15" maxWidth="300" maxHeight="150" style="-fx-background-color: rgba(43, 43, 43, 0.9); -fx-background-radius: 10; -fx-border-color: white; -fx-border-radius: 10; -fx-padding: 20;">
            <Label text="НАСТРОЙКИ" textFill="WHITE">
                <font><Font name="System Bold" size="18.0" /></font>
            </Label>
            <HBox alignment="CENTER" spacing="10">
                <Label text="IP сервера:" textFill="WHITE" />
                <TextField fx:id="ipInput" text="127.0.0.1" prefWidth="100" alignment="CENTER"/>
            </HBox>
            <HBox alignment="CENTER" spacing="10">
                <Label text="Размер поля (от 10):" textFill="WHITE" />
                <TextField fx:id="mapSizeInput" text="20" prefWidth="50" alignment="CENTER"/>
            </HBox>
            <HBox alignment="CENTER" spacing="10">
                <Label text="Количество еды:" textFill="WHITE" />
                <TextField fx:id="foodCountInput" text="1" prefWidth="50" alignment="CENTER"/>
            </HBox>
        </VBox>
    </StackPane>

    <Button fx:id="actionButton" text="СТАРТ" onAction="#handleActionButton" style="-fx-font-size: 18; -fx-cursor: hand;" focusTraversable="false"/>

</VBox>